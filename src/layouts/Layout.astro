---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/portfolio-astro/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Charlie Garcia - Senior Software Engineer" />
    <title>Charlie Garcia | Senior Software Engineer</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { theme } from "../store/theme";

  theme.subscribe((value: "light" | "dark") => {
    if (value === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
    } else {
      document.documentElement.removeAttribute("data-theme");
    }
  });
</script>
